rules_version = '2';

// ===================================================================
// Firestore সিকিউরিটি রুলস — মাল্টি-স্কুল (মাল্টি-টেন্যান্ট) ভার্সন
//
// ⚠️ পরিবর্তন: superAdmin এখন custom claim (Cloud Functions লাগে) দিয়ে না,
// বরং superAdmins/{uid} নামের একটা Firestore ডকুমেন্টের অস্তিত্ব দিয়ে
// যাচাই হয়। এই ডকুমেন্ট Firebase Console থেকে সরাসরি ম্যানুয়ালি বানানো
// যায় — কোনো Cloud Function ডিপ্লয় বা বিলিং লাগবে না।
//
// schoolId/role এখনো custom claim দিয়েই চেক হচ্ছে — এগুলো পরে
// Cloud Functions ডিপ্লয় হলে কাজ করবে (নতুন স্কুল/ইউজার তৈরির সময়)।
// ===================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function mySchoolId() {
      return request.auth.token.schoolId;
    }
    function isSuperAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }
    function belongsToSchool(schoolId) {
      return signedIn() && mySchoolId() == schoolId;
    }
    function isSchoolAdmin(schoolId) {
      return belongsToSchool(schoolId) && request.auth.token.role == 'admin';
    }

    // ===== superAdmins/{uid} — শুধু Firebase Console থেকে ম্যানুয়ালি
    // লেখা হবে, ক্লায়েন্ট থেকে কখনো লেখা/পড়া যাবে না =====
    match /superAdmins/{uid} {
      allow read, write: if false;
    }

    // ===== schools/{schoolId} — স্কুলের প্রোফাইল, প্যাকেজ, মেয়াদ =====
    match /schools/{schoolId} {
      allow read: if belongsToSchool(schoolId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      match /users/{uid} {
        allow read: if belongsToSchool(schoolId) || isSuperAdmin();
        allow write: if isSchoolAdmin(schoolId) || isSuperAdmin();
      }

      match /data/{docId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }
    }

    // ===== পুরনো টপ-লেভেল কালেকশন (payments, sms_logs, attendance) =====
    match /payments/{paymentId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /sms_logs/{logId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /attendance/{recordId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // ডিফল্ট: ওপরে উল্লেখ না থাকা যেকোনো কিছুতে অ্যাক্সেস বন্ধ
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
