rules_version = '2';

// ===================================================================
// Firestore সিকিউরিটি রুলস — মাল্টি-স্কুল (মাল্টি-টেন্যান্ট) ভার্সন
// ✅ সম্পূর্ণভাবে Cloud Function ছাড়াই কাজ করে (Spark/ফ্রি প্ল্যান)
//
// superAdmin → superAdmins/{uid} ডকুমেন্টের অস্তিত্ব দিয়ে যাচাই হয়
//   (Firebase Console থেকে ম্যানুয়ালি বানাতে হয়, একবারই)।
//
// schoolId/role → আগে custom claim দিয়ে চেক হতো (Cloud Function লাগত)।
// এখন এর বদলে userIndex/{uid} নামের একটা ছোট লুকআপ ডকুমেন্ট ব্যবহার হয়:
//   userIndex/{uid} = { schoolId: "...", role: "admin" }
// এই ডকুমেন্ট সুপার-অ্যাডমিন প্যানেল (admin.html) থেকে নতুন স্কুল তৈরির
// সময় ক্লায়েন্ট থেকেই লেখা হয় — কোনো সার্ভার/Cloud Function লাগে না।
// ===================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }
    function hasIndex() {
      return signedIn() &&
        exists(/databases/$(database)/documents/userIndex/$(request.auth.uid));
    }
    function myIndex() {
      return get(/databases/$(database)/documents/userIndex/$(request.auth.uid)).data;
    }
    function belongsToSchool(schoolId) {
      return hasIndex() && myIndex().schoolId == schoolId;
    }
    function isSchoolAdmin(schoolId) {
      return belongsToSchool(schoolId) && myIndex().role == 'admin';
    }

    // ===== superAdmins/{uid} — নিজের ডকুমেন্ট নিজে read করতে পারবে
    // (লগইনের সময় isSuperAdmin কিনা যাচাই করতে ক্লায়েন্ট থেকেই দরকার হয়)।
    // write সবসময় বন্ধ থাকবে — শুধু Firebase Console থেকে ম্যানুয়ালি
    // বানানো/মোছা যাবে =====
    match /superAdmins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ===== usernameIndex/{username} — প্লেইন ইউজারনেম (ইমেইল ফরম্যাট ছাড়া
    // আইডি, যেমন "teacher1") লগইনের জন্য পাবলিক লুকআপ। লগইনের আগে (তখনো
    // signedIn() না) এই ডকুমেন্ট পড়তে হয়, যাতে বোঝা যায় এই আইডিটা কোন
    // স্কুলের/কোন synthetic Firebase Auth ইমেইলের সাথে যুক্ত — তাই read সবার
    // জন্য খোলা (আসল পাসওয়ার্ড এখানে থাকে না, শুধু ইমেইল/schoolId থাকে,
    // পাসওয়ার্ড Firebase Auth নিজেই সামলায়)। create শুধু তখনই সম্ভব যখন এই
    // ইউজারনেম আগে থেকে নেওয়া নেই (Firestore-এর create-vs-update পার্থক্য
    // এটা নিজে থেকেই নিশ্চিত করে) এবং যিনি লিখছেন তিনি নিজের স্কুলের
    // অ্যাডমিন। update/delete শুধু সুপার-অ্যাডমিন করতে পারবে (ইউজারনেম
    // হাইজ্যাক ঠেকাতে) =====
    match /usernameIndex/{username} {
      allow read: if true;
      allow create: if hasIndex() && isSchoolAdmin(request.resource.data.schoolId);
      allow update, delete: if isSuperAdmin();
    }

    // ===== userIndex/{uid} — কোন ইউজার কোন স্কুলের, কী রোল — এই লুকআপ
    // দিয়েই বাকি সব রুলস schoolId/role বের করে। নিজের ডকুমেন্ট নিজে পড়তে
    // পারবে (লগইনের সময় দরকার); সুপার-অ্যাডমিন যেকোনো এন্ট্রি লিখতে পারবে
    // (নতুন স্কুল/অ্যাডমিন তৈরির সময়), স্কুল-অ্যাডমিনও নিজের স্কুলের জন্য
    // নতুন এন্ট্রি বানাতে পারবে (শিক্ষক/অভিভাবক যোগ করার সময়) =====
    match /userIndex/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSuperAdmin() ||
        (hasIndex() && isSchoolAdmin(request.resource.data.schoolId)) ||
        // স্ব-সাইনআপ (Google দিয়ে) — নিজের uid-কেই schoolId হিসেবে, role admin
        // দিয়ে একবারই নিজের userIndex এন্ট্রি বানানো যাবে (ফ্রি ট্রায়াল)
        (signedIn() && request.auth.uid == uid &&
          request.resource.data.schoolId == uid &&
          request.resource.data.role == 'admin');
      allow update, delete: if isSuperAdmin();
    }

    // ===== schools/{schoolId} — স্কুলের প্রোফাইল, প্যাকেজ, মেয়াদ =====
    match /schools/{schoolId} {
      allow read: if belongsToSchool(schoolId) || isSuperAdmin();
      allow create: if isSuperAdmin() ||
        // স্ব-সাইনআপ ট্রায়াল — নিজের uid-কেই schoolId হিসেবে ব্যবহার করে
        // শুধু package='Trial', status='active' দিয়েই বানানো যাবে (একবারই,
        // কারণ 'create' rule শুধু ডকুমেন্ট আগে না থাকলেই চলে)
        (signedIn() && schoolId == request.auth.uid &&
          request.resource.data.package == 'Trial' &&
          request.resource.data.status == 'active' &&
          request.resource.data.expiryDate is timestamp);
      allow update, delete: if isSuperAdmin();

      match /users/{uid} {
        allow read: if belongsToSchool(schoolId) || isSuperAdmin();
        allow write: if isSchoolAdmin(schoolId) || isSuperAdmin();
      }

      match /data/{docId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }

      // ===== schools/{schoolId}/attendance/{clsDateId} — প্রতিটা শ্রেণি+তারিখের
      // উপস্থিতি আলাদা ডকুমেন্ট (আগে data/main-এর ভেতর একটা ফিল্ড ছিল, ১MB
      // লিমিট ও একসাথে-এডিট-করলে-ওভাররাইট সমস্যা এড়াতে আলাদা করা হয়েছে) =====
      match /attendance/{clsDateId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }

      // ===== schools/{schoolId}/students/{studentId}, /fees/{feeId}, /results/{resultId}
      // — attendance-এর মতো একই কারণে এই তিনটাও data/main থেকে বের করে আলাদা
      // কালেকশনে নেওয়া হয়েছে: প্রতিটা ছাত্র/ফি এন্ট্রি/ফলাফল আলাদা ডকুমেন্ট, তাই
      // স্কুল বড় হলেও ১MB লিমিটে ধাক্কা খাবে না, আর দুইজন স্টাফ ভিন্ন রেকর্ড নিয়ে
      // একসাথে কাজ করলে একে অপরের ডেটা ওভাররাইট করবে না =====
      match /students/{studentId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }
      match /fees/{feeId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }
      match /results/{resultId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }

      // ===== schools/{schoolId}/backups/{backupId} — ম্যানুয়াল/অটো ব্যাকআপ
      // পয়েন্টের ক্লাউড কপি (JSON স্ন্যাপশট)। backups/_meta ডকুমেন্টে শেষ
      // ব্যাকআপের সময়/ধরন থাকে, যা সুপার-অ্যাডমিন প্যানেল থেকে সব স্কুলের
      // ব্যাকআপ স্বাস্থ্য (মনিটরিং) দেখতে ব্যবহার হয় =====
      match /backups/{backupId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }
      // ===== schools/{schoolId}/backups/{backupId}/chunks/{chunkId} — ১MB
      // ডকুমেন্ট লিমিট এড়াতে বড় ব্যাকআপ JSON-কে এখানে ছোট ছোট অংশে ভাগ করে
      // রাখা হয় (দেখুন app.html-এর createBackupPoint ফাংশন) =====
      match /backups/{backupId}/chunks/{chunkId} {
        allow read, write: if belongsToSchool(schoolId) || isSuperAdmin();
      }

      // ===== schools/{schoolId}/settings/{docId} — স্কুলের নিজস্ব সেটিংস
      // (যেমন settings/payment = SSLCommerz Store ID/Password)। Store
      // Password-এর মতো sensitive তথ্য থাকে বলে শুধু ওই স্কুলের admin
      // (বা সুপার-অ্যাডমিন) read/write করতে পারবে — সাধারণ শিক্ষক/অভিভাবক
      // এটা পড়তেও পারবে না =====
      match /settings/{docId} {
        allow read, write: if isSchoolAdmin(schoolId) || isSuperAdmin();
      }

      // ===== schools/{schoolId}/payments/{paymentId} — SSLCommerz/bKash
      // পেমেন্টের রেকর্ড কপি। অটো (SSLCommerz) ফ্লোতে এটা মূলত Cloud
      // Function (admin SDK) থেকে লেখা হয়, যা এই rules বাইপাস করে —
      // client-write শুধু স্কুল-অ্যাডমিন/সুপার-অ্যাডমিনের ম্যানুয়াল
      // এন্ট্রির (bKash অ্যাপ্রুভাল কপি, member.html) জন্য খোলা রাখা হলো।
      // read স্কুলের যে কেউ (অভিভাবক সহ) করতে পারবে — পেমেন্ট গেটওয়ে
      // থেকে ফিরে এসে নিজের পেমেন্ট স্ট্যাটাস যাচাই করতে দরকার হয় =====
      match /payments/{paymentId} {
        allow read: if belongsToSchool(schoolId) || isSuperAdmin();
        allow write: if isSchoolAdmin(schoolId) || isSuperAdmin();
      }
    }

    // ===== paymentRequests/{trxId} — bKash/Manual পেমেন্ট → WhatsApp
    // অ্যাপ্রুভাল ফ্লো। trxId-ই ডকুমেন্ট আইডি, তাই একই TrxID দিয়ে দুইবার
    // রিকোয়েস্ট তৈরি করা যাবে না (রিপ্লে-প্রোটেকশন, সম্পূর্ণ পাবলিক/লগইন
    // ছাড়াই সাবমিট করা যায় — pay.html থেকে)। শুধু সুপার-অ্যাডমিন পড়তে/
    // অ্যাপ্রুভ করতে পারবেন (member.html থেকে), আর অ্যাপ্রুভ একবারই সম্ভব
    // কারণ আপডেটের শর্ত resource.data.status == 'pending' বাধ্যতামূলক। =====
    match /paymentRequests/{trxId} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.phone is string
        && request.resource.data.days is number
        && request.resource.data.amount is number;
      allow read: if isSuperAdmin();
      allow update: if isSuperAdmin()
        && resource.data.status == 'pending'
        && request.resource.data.status in ['approved', 'rejected'];
      allow delete: if false;
    }

    // ===== পুরনো টপ-লেভেল কালেকশন (payments, sms_logs, attendance) =====
    match /payments/{paymentId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /sms_logs/{logId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /attendance/{recordId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // ডিফল্ট: ওপরে উল্লেখ না থাকা যেকোনো কিছুতে অ্যাক্সেস বন্ধ
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
